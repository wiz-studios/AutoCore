# Required runtime variables
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_SCHEMA=autocore
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/protected

# Required for server-side confirmed signup
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional operator/admin variables
SUPABASE_URL=https://your-project-ref.supabase.co
POSTGRES_HOST=db.your-project-ref.supabase.co
POSTGRES_DATABASE=postgres
POSTGRES_PASSWORD=your-postgres-password
